# 复制本文件为 application-local.yml，填入你自己的密钥（application-local.yml 已加入 .gitignore，勿提交仓库）
#
# 获取 TRTC SDKAppId / SecretKey：
#   腾讯云控制台 → 实时音视频 TRTC → 应用管理 → 创建应用 → 应用详情 → SDK 密钥
# 获取 DeepSeek API Key：
#   https://platform.deepseek.com/

# ---------- 简历 AI（DeepSeek）----------
llm:
  enabled: true
  api-key: sk-your-deepseek-api-key
  base-url: https://api.deepseek.com
  model: deepseek-chat
  timeout-ms: 60000

# ---------- 面试视频（腾讯云 TRTC）----------
trtc:
  enabled: true
  # 控制台「应用管理」中的 SDKAppID（纯数字）
  sdk-app-id: 0
  # 应用详情 → SDK 密钥（切勿泄露、勿写进前端）
  secret-key: your-trtc-secret-key
  # UserSig 有效期（秒），默认 24 小时
  expire-seconds: 86400
  # 允许进房的面试邀请状态：1=学员已接受
  # 进房时间窗口：面试开始前/后可调整的分钟数（后续接视频房间时用）
  join-window-minutes-before: 30
  join-window-minutes-after: 120
